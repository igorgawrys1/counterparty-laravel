{
    "name": "gawrys/counterparty-laravel",
    "description": "Laravel bridge for counterparty-verification: service provider, config, validation rules, queued verification job and facade.",
    "license": "MIT",
    "type": "library",
    "keywords": ["laravel", "due-diligence", "kyc", "sanctions", "vat"],
    "authors": [
        {
            "name": "Igor Gawrys",
            "email": "igor@fikg.pl"
        }
    ],
    "repositories": [
        {
            "type": "vcs",
            "url": "https://github.com/igorgawrys1/counterparty-core"
        },
        {
            "type": "vcs",
            "url": "https://github.com/igorgawrys1/counterparty-ai"
        }
    ],
    "require": {
        "php": ">=8.2",
        "gawrys/counterparty-core": "^0.1",
        "illuminate/support": "^11.0 || ^12.0",
        "illuminate/contracts": "^11.0 || ^12.0"
    },
    "require-dev": {
        "gawrys/counterparty-ai": "^0.1",
        "orchestra/testbench": "^9.0",
        "phpunit/phpunit": "^11.0",
        "phpstan/phpstan": "^2.0",
        "phpstan/phpstan-phpunit": "^2.0",
        "larastan/larastan": "^3.0",
        "friendsofphp/php-cs-fixer": "^3.64",
        "nyholm/psr7": "^1.8",
        "php-http/mock-client": "^1.6"
    },
    "suggest": {
        "gawrys/counterparty-ai": "Enables AI-assisted advisory risk research (strategy=ai)."
    },
    "autoload": {
        "psr-4": {
            "Gawrys\\Counterparty\\Laravel\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Gawrys\\Counterparty\\Laravel\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Gawrys\\Counterparty\\Laravel\\CounterpartyServiceProvider"
            ],
            "aliases": {
                "Counterparty": "Gawrys\\Counterparty\\Laravel\\Facades\\Counterparty"
            }
        }
    },
    "scripts": {
        "check": ["@cs:check", "@stan", "@test"],
        "cs:check": "php-cs-fixer fix --dry-run --diff --ansi",
        "cs:fix": "php-cs-fixer fix --ansi",
        "stan": "phpstan analyse --ansi --memory-limit=1G",
        "test": "phpunit"
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "php-http/discovery": false
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
